# Copia este archivo como .env.local y coloca tus propios valores
# (NUNCA subas .env.local a GitHub, .env* ya está en .gitignore)

# Clave gratuita de Google Gemini, para el asistente de IA: https://aistudio.google.com/apikey
GEMINI_API_KEY=tu-clave-de-gemini-aqui

# Número de WhatsApp del consultorio, formato internacional sin "+" (ej. 51987654321)
# PENDIENTE: confirmar con el cliente antes de publicar.
NEXT_PUBLIC_WHATSAPP_NUMBER=51999999999

# Dominio final de producción (para SEO, sitemap.xml y Open Graph)
NEXT_PUBLIC_SITE_URL=https://www.drjavierpaino.com

# ID de Google Analytics 4 (opcional, formato G-XXXXXXX). Si se deja vacío, GA4 no se carga.
NEXT_PUBLIC_GA_ID=
